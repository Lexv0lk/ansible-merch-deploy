# Auth service database configuration
DB_AUTH_HOST=postgres_auth
DB_AUTH_PORT=5432
DB_AUTH_USER={{ db_auth_user }}
DB_AUTH_PASSWORD={{ db_auth_password }}
DB_AUTH_NAME={{ db_auth_name }}

# Store service database configuration
DB_STORE_HOST=postgres_store
DB_STORE_PORT=5432
DB_STORE_USER={{ db_store_user }}
DB_STORE_PASSWORD={{ db_store_password }}
DB_STORE_NAME={{ db_store_name }}

# gRPC services ports
GRPC_AUTH_PORT={{ grpc_auth_port }}
GRPC_STORE_PORT={{ grpc_store_port }}

# gRPC services hosts (for gateway)
GRPC_AUTH_HOST={{ grpc_auth_host }}
GRPC_STORE_HOST={{ grpc_store_host }}

# HTTP Gateway port
HTTP_PORT={{ http_port }}

# JWT Secret key
JWT_SECRET={{ jwt_secret }}